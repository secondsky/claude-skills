{
  "description": "Advisory hooks that suggest Bun-equivalent commands (npm/yarn/pnpm -> bun). Advisory only — never blocks.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-bun-command.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/bun-suggestions.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
